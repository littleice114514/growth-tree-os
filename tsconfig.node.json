{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["app/shared/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "app/main/**/*.ts",
    "app/preload/**/*.ts",
    "app/shared/**/*.ts"
  ]
}
